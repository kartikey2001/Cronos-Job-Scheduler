# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://postgres:5432/chronos
DB_USERNAME=chronos
DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be a Base64-encoded secret of at least 256 bits (32 bytes)
JWT_SECRET=change-me-to-a-secure-256-bit-base64-encoded-secret
JWT_EXPIRY_MS=86400000

# ── SMTP / Mail ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=yourapppassword
MAIL_FROM=noreply@chronos.io

# ── Job defaults ──────────────────────────────────────────────────────────────
MAX_RETRIES_DEFAULT=3
RETRY_DELAY_MS_DEFAULT=5000

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_POLL_INTERVAL_MS=10000
